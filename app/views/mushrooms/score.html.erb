<a href="<%= root_path(lat: params[:lat], lon: params[:lon], location_name: params[:location_name], lang: @lang) %>" class="back-link">&#8592; <%= I18nHelper.t(:back_link, @lang) %></a>

<% tier = @result[:tier] %>


<div class="result-card">
  <!-- Score Display -->
  <div class="score-display tier-<%= tier %>">
    <div class="score-circle">
      <span class="number"><%= @result[:score] %></span>
      <span class="out-of">/ 100</span>
    </div>
    <div class="score-label"><%= @result[:label] %></div>
    <div class="score-message"><%= @result[:message] %></div>
  </div>

  <!-- Species info -->
  <div style="text-align: center; margin-bottom: 1rem;">
    <span style="font-size: 0.85rem; color: #999;">
      <%= @result[:species_name] %>
      <em>(<%= @result[:species_latin] %>)</em>
      &middot; <%= @result[:location_name] %>
    </span>
  </div>

  <!-- Score Breakdown (4 factors) -->
  <div class="breakdown">
    <% max_scores = { season: 30, temperature: 30, rain: 30, timing: 10 } %>
    <% stats = @result[:weather_stats] || {} %>
    <% breakdown_labels = {
      season: I18nHelper.t(:season, @lang),
      temperature: I18nHelper.t(:temperature, @lang),
      rain: I18nHelper.t(:rain, @lang),
      timing: I18nHelper.t(:timing, @lang)
    } %>
    <% detail_labels = {
      season: "#{@lang == 'ro' ? ScoringEngine::MONTH_NAMES_RO[Date.today.month] : Date::MONTHNAMES[Date.today.month]}",
      temperature: stats[:avg_temp] ? "#{stats[:avg_temp]}°C avg" : nil,
      rain: stats[:total_rain] ? "#{stats[:total_rain]}mm / 7 #{@lang == 'ro' ? 'zile' : 'days'}" : nil,
      timing: stats[:days_since_rain] ? "#{stats[:days_since_rain]} #{stats[:days_since_rain] == 1 ? (@lang == 'ro' ? 'zi de la ploaie' : 'day since rain') : (@lang == 'ro' ? 'zile de la ploaie' : 'days since rain')}" : nil
    } %>
    <% @result[:breakdown].each do |key, value| %>
      <div class="breakdown-item">
        <label><%= breakdown_labels[key] %></label>
        <div class="bar-track">
          <div class="bar-fill" style="width: <%= (value.to_f / max_scores[key] * 100).round %>%"></div>
        </div>
        <div class="bar-value">
          <%= value %> / <%= max_scores[key] %>
          <% if detail_labels[key] %>
            <span style="color: #bbb; margin-left: 0.3rem;">(<%= detail_labels[key] %>)</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Check Terrain button (AJAX — lazy load on click) -->
  <% unless tier == :"out-of-season" || tier == "out-of-season" %>
    <div class="terrain-check" style="margin: 1rem 0;">
      <button type="button" class="terrain-toggle-btn" id="terrain-btn" onclick="checkTerrain()">
        <%= IconHelper.icon(:map_pin).html_safe %> <%= I18nHelper.t(:check_terrain, @lang) %>
      </button>
      <div id="terrain-detail" class="hidden terrain-detail-box">
        <p id="terrain-loading" style="margin: 0.5rem 0; color: #999; font-size: 0.9rem;">
          <% if @lang == "ro" %>Se detectează terenul…<% else %>Detecting terrain…<% end %>
        </p>
        <div id="terrain-result" class="hidden">
          <p id="terrain-label-text" style="margin: 0.5rem 0 0.25rem; font-weight: 600; color: #555;"></p>
          <p id="terrain-match-text" style="margin: 0; font-size: 0.9rem;"></p>
        </div>
      </div>
    </div>
    <script>
      var terrainLoaded = false;
      function checkTerrain() {
        var detail = document.getElementById('terrain-detail');
        // If already loaded, just toggle visibility
        if (terrainLoaded) {
          detail.classList.toggle('hidden');
          return;
        }
        // Show loading
        detail.classList.remove('hidden');
        document.getElementById('terrain-loading').classList.remove('hidden');
        document.getElementById('terrain-result').classList.add('hidden');
        document.getElementById('terrain-btn').disabled = true;

        var url = '/mushrooms/check_terrain?' +
          'lat=<%= @result[:lat] %>' +
          '&lon=<%= @result[:lon] %>' +
          '&elevation=<%= @result[:elevation] || "" %>' +
          '&species=<%= @result[:species_key] %>' +
          '&lang=<%= @lang %>';

        fetch(url)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            document.getElementById('terrain-loading').classList.add('hidden');
            document.getElementById('terrain-btn').disabled = false;

            if (data.is_water) {
              document.getElementById('terrain-label-text').textContent = data.terrain_label;
              document.getElementById('terrain-match-text').textContent = data.water_message;
              document.getElementById('terrain-match-text').style.color = '#c44';
            } else if (data.is_urban) {
              document.getElementById('terrain-label-text').textContent = data.terrain_label;
              document.getElementById('terrain-match-text').textContent = data.urban_message;
              document.getElementById('terrain-match-text').style.color = '#c44';
            } else if (data.error) {
              document.getElementById('terrain-label-text').textContent = data.terrain_label || 'Error';
              document.getElementById('terrain-match-text').textContent = '';
            } else {
              document.getElementById('terrain-label-text').textContent = data.terrain_label;
              document.getElementById('terrain-match-text').textContent = data.match_text;
              var match = data.terrain_match;
              document.getElementById('terrain-match-text').style.color =
                match === 'ideal' ? '#2a7a2a' :
                match === 'partial' ? '#b8860b' :
                match === 'bad' ? '#c44' : '#999';
            }
            document.getElementById('terrain-result').classList.remove('hidden');
            terrainLoaded = true;
          })
          .catch(function() {
            document.getElementById('terrain-loading').classList.add('hidden');
            document.getElementById('terrain-btn').disabled = false;
            document.getElementById('terrain-label-text').textContent =
              '<%= @lang == "ro" ? "Eroare detecție teren" : "Terrain detection error" %>';
            document.getElementById('terrain-match-text').textContent = '';
            document.getElementById('terrain-result').classList.remove('hidden');
            terrainLoaded = true;
          });
      }
    </script>
  <% end %>

  <!-- Best Time -->
  <% if @result[:best_time] %>
    <div class="best-time-box">
      <span class="clock"><%= IconHelper.icon(:clock).html_safe %></span>
      <div>
        <strong><%= I18nHelper.t(:best_time, @lang) %></strong> <%= @result[:best_time] %>
      </div>
    </div>
  <% end %>

  <!-- Explanation -->
  <div class="info-section">
    <h3><%= I18nHelper.t(:what_data_says, @lang) %></h3>
    <p style="font-size: 1.05rem; color: #555; line-height: 1.7;"><%= @result[:explanation] %></p>
    <% if @result[:weather].present? %>
      <p class="weather-note">
        <%= I18nHelper.t(:currently, @lang) %> <%= @result[:weather][:description] %>,
        <%= @result[:weather][:current_temp] %>&deg;C,
        <%= I18nHelper.t(:humidity, @lang) %> <%= @result[:weather][:humidity] %>%
        <% if @result[:weather_stats][:elevation] %>
          &middot; <%= @result[:weather_stats][:elevation].round %>m alt.
        <% end %>
      </p>
      <% if @result[:weather][:rain_daily].present? && @result[:weather][:rain_daily].any? %>
        <div class="rain-chart">
          <p style="font-size: 0.8rem; color: #999; margin-bottom: 0.5rem;"><%= IconHelper.icon(:rain_cloud).html_safe %> <%= I18nHelper.t(:rainfall_chart, @lang) %></p>
          <div class="rain-bars">
            <% max_rain = [@result[:weather][:rain_daily].map { |d| d[:rain_mm] }.max, 1].max %>
            <% @result[:weather][:rain_daily].each do |day| %>
              <div class="rain-bar-col">
                <div class="rain-bar-value"><%= day[:rain_mm] > 0 ? day[:rain_mm].round(1) : "" %></div>
                <div class="rain-bar-track">
                  <div class="rain-bar-fill" style="height: <%= (day[:rain_mm] / max_rain * 100).round %>%"></div>
                </div>
                <div class="rain-bar-date"><%= Date.parse(day[:date]).strftime("%-d/%-m") %></div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Foraging Tips -->
  <div class="info-section">
    <h3><%= I18nHelper.t(:foraging_tips, @lang) %></h3>
    <ul class="info-list tips">
      <% @result[:tips].each do |tip| %>
        <li><%= tip.html_safe %></li>
      <% end %>
    </ul>
  </div>
</div>
